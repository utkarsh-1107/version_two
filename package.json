{
  "name": "food-order-management-v1",
  "version": "1.0.0",
  "description": "Local web-based food order management system",
  "main": "server.js",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:init:postgres": "node -e \"require('./database-postgres').initDatabase().then(()=>{console.log('Postgres schema ready');process.exit(0);}).catch((e)=>{console.error(e);process.exit(1);})\"",
    "migrate:postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "migrate:supabase": "node scripts/migrate-sqlite-to-postgres.js",
    "seed:generate": "node scripts/generate-seed-sql.js",
    "seed:apply": "node scripts/apply-seed-sql.js",
    "smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "body-parser": "^1.20.3",
    "express": "^4.21.2",
    "pdfkit": "^0.15.2",
    "pg": "^8.11.5",
    "sqlite3": "^5.0.2"
  }
}
