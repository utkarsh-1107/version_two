# Supabase/Postgres connection string (pooler URL recommended)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Keep enabled for Supabase TLS compatibility in this app
PGSSL=1

# Use 0 or remove for read/write mode
READ_ONLY=0

# Optional admin PIN used by DELETE /orders/:id
ADMIN_PIN=1234
